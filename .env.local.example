# Required — Vercel AI Gateway key (routes Anthropic + other providers)
# Get from: https://vercel.com/dashboard → AI Gateway → API Keys
VERCEL_AI_GATEWAY_KEY=vck_...

# Optional for local dev, required for production rate limiting
# Get from: https://console.upstash.com/ → create a Redis database
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Chatroom experiment (Cloudflare Worker hosting the Durable Object)
# WSS URL for the deployed worker. For local-only dev, use ws://localhost:8787
NEXT_PUBLIC_CHATROOM_WSS_URL=wss://sandbox-chatroom.<account>.workers.dev

# HMAC secret for signing one-shot WS upgrade tickets. Must match the value
# set as a wrangler secret on the Cloudflare worker. Generate with:
#   openssl rand -hex 32
TICKET_SECRET=
